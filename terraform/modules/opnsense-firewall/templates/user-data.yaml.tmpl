#cloud-config
# nuageinit (FreeBSD's in-tree cloud-init substitute) silently drops
# `runcmd` — we can't rely on it to kick off opnsense-bootstrap. Instead
# we write a self-deleting /etc/rc.local via write_files; FreeBSD always
# runs rc.local at the end of boot if it exists, with no dependency on
# runcmd support. nuageinit also won't mkdir -p parents for write_files,
# so we stage config.xml in /tmp and rc.local moves it to /conf.
hostname: ${hostname}

users:
  - name: root
    ssh_authorized_keys:
      - ${ssh_key}

write_files:
  - path: /tmp/opnsense-config.xml
    permissions: "0600"
    owner: root:wheel
    content: |
      ${indent(6, config_xml)}
  - path: /etc/rc.local
    permissions: "0755"
    owner: root:wheel
    content: |
      #!/bin/sh
      # Self-deleting one-shot: runs opnsense-bootstrap on first boot,
      # then removes itself so it doesn't re-fire on future boots.
      rm -f /etc/rc.local
      set -eux
      exec > /var/log/opnsense-bootstrap.log 2>&1
      mkdir -p /conf
      mv /tmp/opnsense-config.xml /conf/config.xml
      chmod 0600 /conf/config.xml
      fetch -o /tmp/opnsense-bootstrap.sh \
        https://raw.githubusercontent.com/opnsense/update/master/src/bootstrap/opnsense-bootstrap.sh.in
      # -f preserves /conf/config.xml (seeded above), -y answers prompts.
      sh /tmp/opnsense-bootstrap.sh -r ${opnsense_release} -f -y
      # opnsense-bootstrap reboots itself on success.
