<?xml version="1.0"?>
<opnsense>
  <theme>opnsense</theme>
  <sysctl/>
  <system>
    <optimization>normal</optimization>
    <hostname>${hostname}</hostname>
    <domain>${domain}</domain>
    <dnsallowoverride>1</dnsallowoverride>
    <group>
      <name>admins</name>
      <description>System Administrators</description>
      <scope>system</scope>
      <gid>1999</gid>
      <member>0</member>
      <priv>page-all</priv>
    </group>
    <user>
      <name>root</name>
      <descr>System Administrator</descr>
      <scope>system</scope>
      <groupname>admins</groupname>
      <uid>0</uid>
      <authorizedkeys>${base64encode(ssh_key)}</authorizedkeys>
      <apikeys>
        <item>
          <key>${api_key_id}</key>
          <secret>${api_key_secret_hash}</secret>
        </item>
      </apikeys>
    </user>
    <nextuid>2000</nextuid>
    <nextgid>2000</nextgid>
    <timezone>UTC</timezone>
    <timeservers>0.opnsense.pool.ntp.org 1.opnsense.pool.ntp.org 2.opnsense.pool.ntp.org 3.opnsense.pool.ntp.org</timeservers>
    <webgui>
      <protocol>https</protocol>
      <port>443</port>
      <ssl-ciphers/>
    </webgui>
    <disablenatreflection>yes</disablenatreflection>
%{ for dns in dns_servers ~}
    <dnsserver>${dns}</dnsserver>
%{ endfor ~}
    <serialspeed>115200</serialspeed>
    <primaryconsole>serial</primaryconsole>
  </system>
  <interfaces>
    <wan>
      <enable>1</enable>
      <if>vtnet0</if>
      <descr>WAN</descr>
      <ipaddr>dhcp</ipaddr>
      <ipaddrv6>dhcp6</ipaddrv6>
      <blockbogons>1</blockbogons>
    </wan>
    <lan>
      <enable>1</enable>
      <if>vtnet1</if>
      <descr>LAN</descr>
      <ipaddr>${lan_ip}</ipaddr>
      <subnet>${lan_prefix}</subnet>
    </lan>
  </interfaces>
  <dhcpd/>
  <unbound>
    <enable>1</enable>
  </unbound>
  <snmpd>
    <syslocation/>
    <syscontact/>
    <rocommunity>public</rocommunity>
  </snmpd>
  <nat>
    <outbound>
      <mode>automatic</mode>
    </outbound>
  </nat>
  <filter>
    <rule>
      <type>pass</type>
      <ipprotocol>inet</ipprotocol>
      <descr>Default allow LAN to any rule</descr>
      <interface>lan</interface>
      <source>
        <network>lan</network>
      </source>
      <destination>
        <any/>
      </destination>
    </rule>
    <rule>
      <type>pass</type>
      <ipprotocol>inet6</ipprotocol>
      <descr>Default allow LAN IPv6 to any rule</descr>
      <interface>lan</interface>
      <source>
        <network>lan</network>
      </source>
      <destination>
        <any/>
      </destination>
    </rule>
%{ if operator_ingress_cidr != "" ~}
    <rule>
      <type>pass</type>
      <ipprotocol>inet</ipprotocol>
      <protocol>tcp</protocol>
      <descr>Operator SSH + HTTPS access to OPNsense WAN</descr>
      <interface>wan</interface>
      <source>
        <address>${operator_ingress_cidr}</address>
      </source>
      <destination>
        <network>wanip</network>
        <port>22 443</port>
      </destination>
    </rule>
%{ endif ~}
  </filter>
  <rrd>
    <enable/>
  </rrd>
  <widgets>
    <sequence>system_information-container:col1:show,services_status-container:col1:show,interface_list-container:col2:show,gateways-container:col2:show</sequence>
    <column_count>2</column_count>
  </widgets>
  <revision>
    <username>root@bootstrap</username>
    <time>1714780800</time>
    <description>Bootstrap config generated by Zakros Terraform</description>
  </revision>
  <OPNsense/>
</opnsense>
